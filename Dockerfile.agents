FROM python:3.11-slim

# gcc is needed by some pandas-ta / numpy native extensions
RUN apt-get update && apt-get install -y --no-install-recommends gcc git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install agent dependencies (cached layer — only rebuilds when requirements change)
COPY backend/jobs/agents_requirements.txt ./
RUN pip install --no-cache-dir -r agents_requirements.txt

# Copy the full backend source (orchestrator imports from agents/, db/, data/, risk/)
COPY backend/ ./backend/

CMD ["python", "backend/jobs/run_agents.py"]
