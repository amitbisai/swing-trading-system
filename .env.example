# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Market Data ───────────────────────────────────────────────────────────────
FINNHUB_API_KEY=your-finnhub-api-key          # free tier: 60 calls/min — used for batch sentiment
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key  # legacy — no longer used for sentiment

# ── Cache / Task Queue (Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Notifications (Telegram) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend (public — safe to expose in NEXT_PUBLIC_* vars) ─────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── T2 Screener thresholds (all optional — defaults shown) ───────────────────
T2_MAX_PCT_BELOW_52W_HIGH=0.30   # within 30% of 52W high (relaxed from 15%)
T2_RVOL_MIN=1.5                  # min relative volume (relaxed from 2.0x)
T2_REQUIRE_ABOVE_200DMA=false    # skip 200 DMA gate in weak-market conditions
T2_MAX_RESULTS=20                # max T2 candidates per nightly run
T2_MIN_MARKET_CAP=300000000      # $300M
T2_MAX_MARKET_CAP=15000000000    # $15B
T2_MIN_PRICE=10.0
T2_MIN_AVG_VOLUME=500000

# ── Risk / trading engine (all optional — defaults shown) ────────────────────
INITIAL_CAPITAL=100000
RISK_PER_TRADE_PCT=0.01          # size so a stop-out loses 1% of capital
MAX_POSITION_PCT=0.15            # never put more than 15% of capital in one stock
MAX_DAILY_DEPLOYMENT_PCT=0.25    # at most 25% of capital put to work per day
MIN_CASH_RESERVE_PCT=0.10        # cash never drops below 10% of capital
MAX_T2_ENTRIES_PER_DAY=5         # hard daily ceiling on count-exempt T2 entries
T1_MIN_EARNINGS_DAYS=8           # drop T1 signals with earnings within 8 days
MAX_ENTRY_GAP_PCT=0.015          # skip auto-entry if price ran >1.5% past signal entry
LONG_ONLY=true                   # skip SHORT signals (backtest: +18.0% -> +32.5%)
MAX_OPEN_POSITIONS=0             # 0 = unlimited
MAX_HOLDING_DAYS=14              # time-exit: close trades after N calendar days (0 = off)
ATR_STOP_MULT=1.5                # stop  = entry − 1.5 × ATR(14)
ATR_TARGET_MULT=3.0              # target = entry + 3.0 × ATR(14)
REGIME_FILTER_ENABLED=true       # suppress new entries when SPY < 200-day SMA
REGIME_SYMBOL=SPY
AUTO_ENTRY_MODE=intraday         # "intraday" = trades open next morning at live prices
                                 # via the hourly job; "nightly" = open right after agents run

# ── Runtime environment ───────────────────────────────────────────────────────
ENVIRONMENT=development
